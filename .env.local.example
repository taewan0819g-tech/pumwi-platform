# Supabase 환경 변수
# Supabase 프로젝트 설정에서 다음 값들을 가져와서 설정하세요:
# Dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Maps API (프로필 위치 검색·좌표 저장용)
# Google Cloud Console > APIs & Services > Enable Maps JavaScript API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Toss Payments (컬렉터 소장하기 결제)
# 토스페이먼츠 개발자센터에서 발급 (테스트: test_ck_xxx, 라이브: live_ck_xxx)
NEXT_PUBLIC_TOSS_CLIENT_KEY=your_toss_client_key
# 결제 승인 API용 시크릿 키 (서버 전용, 노출 금지)
TOSS_SECRET_KEY=your_toss_secret_key
